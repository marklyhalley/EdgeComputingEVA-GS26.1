            ]
        ]
    },
    {
        "id": "9bd839d877d74629",
        "type": "function",
        "z": "3b379457e588837b",
        "name": "Parse Status + Cor",
        "func": "var nivel = msg.payload.nivel;\nvar desc  = msg.payload.descricao;\n\nvar cor = '#00c400';\nif (nivel === 1) cor = '#e6a817';\nif (nivel === 2) cor = '#e60000';\n\n// saída 1 → texto de status (sempre)\nvar textMsg = RED.util.cloneMessage(msg);\ntextMsg.payload = desc;\ntextMsg.style   = { color: cor, 'font-size': '24px', 'font-weight': 'bold' };\n\n// saída 2 → toast (somente WARNING ou CRITICAL)\nvar alertMsg = null;\nif (nivel >= 1) {\n    var icone = nivel === 1 ? '⚠️' : '🔴';\n    alertMsg = RED.util.cloneMessage(msg);\n    alertMsg.payload = icone + ' ' + desc + ' — nível ' + nivel;\n    alertMsg.topic   = nivel === 2 ? 'error' : 'warning';\n}\n\nreturn [textMsg, alertMsg];",
        "outputs": 2,
        "x": 340,
        "y": 620,
        "wires": [
            [
                "a94a4001d95a2e99"
            ],
            [
                "fc9d0b100dd3bc13"
            ]
        ]
    },
