        "type": "mqtt in",
        "z": "3b379457e588837b",
        "name": "Sub: status",
        "topic": "dragon/telemetry/status",
        "qos": "1",
        "datatype": "json",
        "broker": "mqtt_broker_cfg",
        "inputs": 0,
